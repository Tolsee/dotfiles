#!/bin/bash
# Wire the shared agent rules into each agent's global config.
#
# - Claude Code: ~/.claude/CLAUDE.md + RTK.md are symlinks into dotfiles/ai/claude/
#   (CLAUDE.md @-imports ai/agents/AGENTS.md, so plugin edits stay tracked in git).
# - Codex / Gemini: their global files are NOT symlinked — codex's is
#   tool-managed (ltd-skill) and gemini appends memories to its file — so we
#   only ensure a pointer/import line exists.
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/../.." && pwd)"
SHARED="$DOTFILES/ai/agents/AGENTS.md"

# Claude Code
mkdir -p ~/.claude
for f in CLAUDE.md RTK.md; do
  ln -sf "$DOTFILES/ai/claude/$f" ~/.claude/"$f"
done
echo "linked ~/.claude/{CLAUDE.md,RTK.md} -> $DOTFILES/ai/claude/"

# Codex — append pointer if missing
if [ -e ~/.codex ]; then
  if grep -q "dotfiles/agents/AGENTS.md" ~/.codex/AGENTS.md 2>/dev/null; then
    perl -0pi -e 's#dotfiles/agents/AGENTS\.md#dotfiles/ai/agents/AGENTS.md#g' ~/.codex/AGENTS.md
    echo "migrated pointer in ~/.codex/AGENTS.md"
  elif ! grep -q "dotfiles/ai/agents/AGENTS.md" ~/.codex/AGENTS.md 2>/dev/null; then
    printf '\n## Global Rules\n\nAlso read and follow %s (shared rules for all coding agents).\n' "$SHARED" >> ~/.codex/AGENTS.md
    echo "added pointer to ~/.codex/AGENTS.md"
  fi
fi

# Gemini / Antigravity — append import if missing
if [ -e ~/.gemini ]; then
  if grep -q "dotfiles/agents/AGENTS.md" ~/.gemini/GEMINI.md 2>/dev/null; then
    perl -0pi -e 's#dotfiles/agents/AGENTS\.md#dotfiles/ai/agents/AGENTS.md#g' ~/.gemini/GEMINI.md
    echo "migrated import in ~/.gemini/GEMINI.md"
  elif ! grep -q "dotfiles/ai/agents/AGENTS.md" ~/.gemini/GEMINI.md 2>/dev/null; then
    printf '\n@%s\n' "$SHARED" >> ~/.gemini/GEMINI.md
    echo "added import to ~/.gemini/GEMINI.md"
  fi
fi

echo "done"
